---
import Base from "../../layouts/Base.astro";
import { assessments } from "../../data/assessments.js";
import { getLangFromUrl, localizePath } from "../../i18n/utils.js";

// Bron: Sanity als SANITY_PROJECT_ID is gezet, anders de lokale databestanden (build werkt altijd).
export async function getStaticPaths() {
  if (import.meta.env.SANITY_PROJECT_ID) {
    const { sanity } = await import("../../lib/sanity.js");
    const { allAssessmentSlugs } = await import("../../lib/queries.js");
    const slugs = await sanity.fetch(allAssessmentSlugs);
    return slugs.map((slug) => ({ params: { slug } }));
  }
  return assessments.map((a) => ({ params: { slug: a.slug }, props: { a } }));
}

const lang = getLangFromUrl(Astro.url);
let a = Astro.props.a;
if (!a) {
  const { sanity, pick } = await import("../../lib/sanity.js");
  const { assessmentBySlug } = await import("../../lib/queries.js");
  const r = await sanity.fetch(assessmentBySlug, { slug: Astro.params.slug });
  const initials = (r?.quote?.author || "").split(" ").map((w) => w[0]).join("").slice(0, 2);
  a = {
    title: pick(r.title, lang), phase: pick(r.phase, lang), goal: pick(r.goal, lang),
    time: pick(r.time, lang), form: pick(r.form, lang), feedback: pick(r.feedback, lang), extra: pick(r.extra, lang),
    traits: (r.traits || []).map((t) => pick(t, lang)),
    intro: (r.intro || []).map((p) => pick(p, lang)),
    body: (r.body || []).map((p) => pick(p, lang)),
    quote: { heading: pick(r.quote?.heading, lang), text: pick(r.quote?.text, lang), author: r.quote?.author || "", role: pick(r.quote?.role, lang), initials },
    faq: (r.faq || []).map((f) => ({ q: pick(f.q, lang), a: pick(f.a, lang) })),
    metaTitle: pick(r.title, lang), metaDescription: pick(r.goal, lang), related: [],
  };
}
const assessHref = localizePath("/online-assessments/", lang);
---
<Base title={a.metaTitle} description={a.metaDescription} active="assessments">
  <div class="crumb">
    <div class="wrap"><a href={localizePath("/", lang)}>Home</a> › <a href={assessHref}>Online assessments</a> › <span>{a.title}</span></div>
  </div>

  <section class="ahero">
    <div class="wrap">
      <div>
        <div class="eyebrow">Online assessments</div>
        <h1>{a.title}</h1>
        <div class="meta-row"><span class="lbl">Fase</span><span class="val">{a.phase}</span></div>
        <div class="meta-row"><span class="lbl">Doel</span><span class="val">{a.goal}</span></div>
        <div class="btns">
          <a href={localizePath("/contact/", lang)} class="btn btn-primary">Gratis demo</a>
          <a href="#request" class="btn btn-light">Direct starten</a>
        </div>
        <div class="guarantee">
          <strong style="color:#fff">Niet tevreden? Geld terug!</strong>
          <span><span class="stars">★★★★★</span> 10.000+ deelnemers · <b style="color:#fff">4,9/5 sterren</b></span>
        </div>
      </div>
      <div class="device">
        <div class="screen">
          <span class="chip">Voorbeeldrapport</span>
          {a.traits.map((t, i) => (
            <div class="traitbar"><span>{t}</span><div class="track"><div class="fill" style={`width:${40 + ((i * 13) % 50)}%`}></div></div></div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <div class="infobar">
    <div class="wrap">
      <div class="info-grid">
        <div><div class="lbl">Tijd</div><div class="v">{a.time}</div></div>
        <div><div class="lbl">Vorm</div><div class="v">{a.form}</div></div>
        <div><div class="lbl">Feedback</div><div class="v">{a.feedback}</div></div>
        <div><div class="lbl">Extra</div><div class="v">{a.extra}</div></div>
      </div>
    </div>
  </div>

  <section>
    <div class="wrap">
      <div class="eyebrow">Uitleg</div>
      <h2 class="section-title">{a.title}</h2>
      <div class="explain">
        <div>
          {a.intro.map((p) => <p>{p}</p>)}
          {a.traits.length > 0 && <ul class="traits">{a.traits.map((t) => <li>{t}</li>)}</ul>}
          {a.body.map((p) => <p>{p}</p>)}
          <a href="#request" class="btn btn-primary" style="margin-top:8px">Direct starten</a>
        </div>
        <div class="pentagon">
          <div class="ring"></div>
          <p style="color:var(--muted);font-size:14px">De kerndimensies van dit assessment, vertaald naar werkgerelateerde inzichten.</p>
        </div>
      </div>
    </div>
  </section>

  {a.quote.text && (
    <section class="quote">
      <div class="wrap">
        <div class="avatar">{a.quote.initials}</div>
        <div>
          <h3>{a.quote.heading}</h3>
          <blockquote>"{a.quote.text}"</blockquote>
          <div class="who"><b>{a.quote.author}</b> — {a.quote.role}</div>
        </div>
      </div>
    </section>
  )}

  <section>
    <div class="wrap">
      <div class="center">
        <div class="eyebrow">Veelgestelde vragen</div>
        <h2 class="section-title" style="margin-bottom:42px">Alles over {a.title}</h2>
      </div>
      <div style="max-width:820px;margin:0 auto">
        {a.faq.map((f) => (
          <div class="faq-item">
            <div class="faq-q">{f.q}<span class="pl">+</span></div>
            <div class="faq-a"><p>{f.a}</p></div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="formsec" id="request">
    <div class="wrap">
      <div class="center">
        <div class="eyebrow">Aanvragen</div>
        <h2 class="section-title">{a.title} aanvragen</h2>
        <p class="lead" style="margin-bottom:36px">Vul het formulier in en krijg binnen 24 uur toegang.</p>
      </div>
      <form class="formcard" action="https://formspree.io/f/JOUW_FORM_ID" method="POST">
        <div class="frow">
          <div class="fg"><label>Voornaam *</label><input type="text" name="voornaam" required /></div>
          <div class="fg"><label>Werk e-mail *</label><input type="email" name="email" required /></div>
        </div>
        <div class="fg"><label>Bedrijfsnaam</label><input type="text" name="bedrijf" /></div>
        <button type="submit" class="btn btn-primary">Verzenden</button>
      </form>
    </div>
  </section>
</Base>
