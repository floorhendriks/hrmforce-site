---
import Base from "../layouts/Base.astro";
import { posts as localPosts } from "../data/blog.js";
import { getLangFromUrl, localizePath } from "../i18n/utils.js";

const lang = getLangFromUrl(Astro.url);
let list = localPosts.map((p) => ({ slug: p.slug, category: p.category, date: p.date, title: p.title, excerpt: p.excerpt }));
if (import.meta.env.SANITY_PROJECT_ID) {
  const { sanity, pick } = await import("../lib/sanity.js");
  const { allPosts } = await import("../lib/queries.js");
  const raw = await sanity.fetch(allPosts);
  list = raw.map((p) => ({ slug: p.slug?.current, category: pick(p.category, lang), date: p.date, title: pick(p.title, lang), excerpt: pick(p.excerpt, lang) }));
}
const fmt = (d) => new Date(d).toLocaleDateString("nl-NL");
---
<Base title="Kenniscentrum | Hrmforce" description="Artikelen over HR, assessments, capaciteiten en ontwikkeling." active="">
  <div class="crumb"><div class="wrap"><a href={localizePath("/", lang)}>Home</a> › <span>Kenniscentrum</span></div></div>
  <section class="ahero"><div class="wrap" style="display:block">
    <div class="eyebrow" style="color:var(--gold)">Kenniscentrum</div>
    <h1>Kennis & inzichten</h1>
    <p style="color:#c4d2e6;font-size:19px;max-width:760px;margin-top:8px">Artikelen over talentmanagement, assessments, capaciteiten en ontwikkeling.</p>
  </div></section>
  <section class="blog"><div class="wrap">
    <div class="posts">
      {list.map((p) => (
        <a class="post" href={`${localizePath("/kenniscentrum/", lang)}${p.slug}/`} style="text-decoration:none">
          <div class="img"></div>
          <div class="body"><span class="tag">{p.category}</span><h3>{p.title}</h3><span class="date">{fmt(p.date)}</span></div>
        </a>
      ))}
    </div>
  </div></section>
</Base>
