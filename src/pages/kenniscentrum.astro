---
import Base from "../layouts/Base.astro";
import { createClient } from "@sanity/client";
import { getLangFromUrl, localizePath } from "../i18n/utils.js";

const lang = getLangFromUrl(Astro.url);

// Gemigreerde kenniscentrum-artikelen uit Sanity (vaste, publieke client).
const client = createClient({
  projectId: "hqo56w28",
  dataset: "production",
  apiVersion: "2024-01-01",
  useCdn: false,
});
const raw = await client.fetch(
  `*[_type == "article" && defined(path) && defined(body) && path match "/kenniscentrum/*"] | order(date desc){title, path, date}`
);
const list = raw.filter((p) => p.path && p.title);
const fmt = (d) => (d ? new Date(d).toLocaleDateString("nl-NL") : "");
---
<Base title="Kenniscentrum | Hrmforce" description="Artikelen over HR, assessments, capaciteiten en ontwikkeling." active="">
  <div class="crumb"><div class="wrap"><a href={localizePath("/", lang)}>Home</a> › <span>Kenniscentrum</span></div></div>
  <section class="ahero"><div class="wrap" style="display:block">
    <div class="eyebrow" style="color:var(--gold)">Kenniscentrum</div>
    <h1>Kennis & inzichten</h1>
    <p style="color:#c4d2e6;font-size:19px;max-width:760px;margin-top:8px">Artikelen over talentmanagement, assessments, capaciteiten en ontwikkeling.</p>
  </div></section>
  <section class="blog"><div class="wrap">
    <div class="posts">
      {list.map((p) => (
        <a class="post" href={p.path} style="text-decoration:none">
          <div class="img"></div>
          <div class="body"><h3>{p.title}</h3><span class="date">{fmt(p.date)}</span></div>
        </a>
      ))}
    </div>
  </div></section>
</Base>
